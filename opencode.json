{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5",
  "default_agent": "build",
  "share": "disabled",
  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      "repos/**",
      "worktrees/**",
      "records/**",
      ".tmp/**"
    ]
  },
  "agent": {
    "build": {
      "permission": {
        "bash": {
          "*": "allow",
          "rm -rf *": "deny",
          "git reset --hard*": "deny",
          "git checkout -- *": "deny",
          "git clean *": "deny",
          "git push --force*": "deny"
        }
      }
    },
    "plan": {
      "permission": {
        "edit": "deny",
        "bash": "deny"
      }
    }
  }
}
