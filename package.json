{
  "name": "prer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "description": "OpenCode orchestrator for continuously fixing valuable OSS issues and opening PRs.",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "check": "pnpm typecheck && pnpm build",
    "start": "node dist/src/main.js",
    "dev": "tsx src/main.ts",
    "bootstrap": "tsx scripts/bootstrap.ts"
  },
  "dependencies": {
    "@opencode-ai/sdk": "^1.14.29"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
